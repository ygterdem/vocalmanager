{
  "name": "vocalmanager",
  "version": "0.3.0",
  "description": "Background vocal-training reminder app with real-time pitch feedback, tuned for low male voices.",
  "main": "main.js",
  "scripts": {
    "build:vendor": "esbuild --bundle --format=esm --platform=browser --outfile=renderer/vendor/pitchy.bundle.js node_modules/pitchy/index.js",
    "prestart": "npm run build:vendor",
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "test": "vitest run",
    "test:watch": "vitest",
    "dist": "npm run build:vendor && electron-builder --publish never",
    "release": "npm run build:vendor && electron-builder --publish always"
  },
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ygterdem/vocalmanager.git"
  },
  "build": {
    "appId": "com.vocalmanager.app",
    "productName": "Vocal Manager",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "!**/*.map",
      "!tests/**",
      "!**/*.test.js"
    ],
    "win": {
      "target": "nsis",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "publish": {
      "provider": "github",
      "owner": "ygterdem",
      "repo": "vocalmanager",
      "releaseType": "release"
    }
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.28.0",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "pitchy": "^4.1.0"
  }
}
